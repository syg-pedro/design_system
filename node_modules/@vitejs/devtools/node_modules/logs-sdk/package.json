  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "vitest",
    "play": "pnpm -C playground run dev",
    "lint": "eslint",
    "release": "node scripts/release.ts",
    "test": "pnpm run build && pnpm -r run build && tsc && eslint && vitest run",
    "typecheck": "tsc"
