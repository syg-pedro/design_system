    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@antfu/ni": "^30.0.0",
    "@antfu/utils": "^9.3.0",
    "@posva/prompts": "^2.4.4",
    "@types/node": "^25.6.0",
    "@types/semver": "^7.7.1",
    "bumpp": "^11.0.1",
    "conventional-changelog": "^7.2.0",
    "conventional-changelog-angular": "^8.3.1",
